APP_NAME="AUTOFIX IA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Base de datos ---
# Opción A (recomendada en el proyecto): PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=taller_automotriz_db
DB_USERNAME=postgres
DB_PASSWORD=

# Opción B: SQLite (alternativa rápida)
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@autofix.test"
MAIL_FROM_NAME="${APP_NAME}"

# --- Groq API (Semana 3 - módulo IA) ---
# Cada estudiante crea su propia key en https://console.groq.com/keys
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MOCK=true
# En Windows local, si aparece cURL error 60, usa false solo en desarrollo
GROQ_SSL_VERIFY=true

# --- Facturación (IVA Ecuador 15% por defecto) ---
FACTURA_IVA_RATE=0.15
FACTURA_SERIE=F001

# Tests (phpunit.xml): usa PostgreSQL DB "taller_automotriz_test"
# CREATE DATABASE taller_automotriz_test;

VITE_APP_NAME="${APP_NAME}"
